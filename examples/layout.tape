Output examples/output/layout.gif

Require printf

Set Shell "bash"
Set Theme "GitHub Light Default"
Set FontSize 24
Set Width 980
Set Height 520
Set Padding 72
Set Margin 24
Set MarginFill "#1d3557"
Set WindowBar ColorfulRight
Set WindowBarSize 42
Set BorderRadius 16
Set CursorBlink false

Type "printf 'padding margin window-bar border-radius\n'"
Enter
Wait+Screen "border-radius"

Sleep 900ms
Hide
Type "exit"
Enter
